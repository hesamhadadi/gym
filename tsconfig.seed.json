{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "jsx": "preserve",
    "outDir": "./dist-seed",
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
